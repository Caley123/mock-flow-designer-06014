# Variables opcionales para pruebas de carga (copiar a .env.local)

# Pool de estudiantes a usar en escaneos/consultas
LOAD_STUDENT_POOL=800

# Portal padres: total y duración
LOAD_PARENT_TOTAL=10000
LOAD_DURATION_MIN=30

# Tutores (mínimo 4 para prueba realista)
LOAD_TUTOR_COUNT=4
LOAD_TUTOR_ACCOUNTS=TutorRudeus:clave1,Tutor2:clave2,Tutor3:clave3,Tutor4:clave4

# WhatsApp
LOAD_WA_MAX=50
LOAD_WA_INTERVAL_MS=3000
LOAD_OPENWA_API_URL=http://localhost:2785/api
