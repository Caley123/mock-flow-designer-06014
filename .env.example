# WhatsApp — OpenWA (https://github.com/rmyndharis/OpenWA) — NO requiere Docker
# 1. cd OpenWA && npm install && copy .env.minimal .env && npm run dev
#    (o desde SIE: .\scripts\iniciar-openwa.ps1)
# 2. Dashboard http://localhost:2886 — sesión + QR + API Key + Session ID
VITE_OPENWA_ENABLED=true
VITE_OPENWA_API_URL=/api/openwa
VITE_OPENWA_SESSION_ID=
VITE_OPENWA_API_KEY=
