# =============================================================================
# SIE — variables de entorno (copiar a .env.local en desarrollo)
# En Cloudflare: Dashboard → Workers → sie → Settings → Variables (Build)
# =============================================================================

# Supabase (obligatorio en producción si cambias de proyecto)
VITE_SUPABASE_URL=https://spdugaykkcgpcfslcpac.supabase.co
VITE_SUPABASE_ANON_KEY=

# URL pública del frontend (enlaces en mensajes WhatsApp). También en .env.production para el build.
VITE_APP_URL=https://sie.rudeusgreiyart7000.workers.dev

# Google Analytics 4 (opcional — también actualizar CSP en Caddy si se activa)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

VITE_OPENWA_ENABLED=false
VITE_OPENWA_API_URL=/api
VITE_OPENWA_SESSION_ID=
VITE_OPENWA_API_KEY=

# WPPConnect Server (recomendado en VPS — sesiones persistentes)
VITE_WPPCONNECT_ENABLED=false
VITE_WPPCONNECT_API_URL=/wpp-api
VITE_WPPCONNECT_SESSION=sie-chip-01
VITE_WPPCONNECT_TOKEN=

# Rotación multi-chip (7 números, cola en VPS con anti-baneo)
VITE_WPPCONNECT_ROTATION=false
VITE_WPPCONNECT_NOTIFY_URL=/wpp-notify
VITE_WPPCONNECT_NOTIFY_KEY=

# Meta WhatsApp Cloud API — SOLO Jean Piaget (token en /opt/sie-jp/.env.meta-wa)
# En San Ramón dejar en false o omitir.
# VITE_TALLERES_ENABLED=true
VITE_META_WA_ENABLED=false
VITE_META_WA_API_URL=/meta-wa
VITE_META_WA_NOTIFY_KEY=

# (Opcional, solo pruebas locales sin cola) destino fijo si no hay rotación WPPConnect
# VITE_WHATSAPP_OPERATOR_PHONE=900116737
